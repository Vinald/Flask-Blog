# Flask Configuration
SECRET_KEY=your-secret-key-here
FLASK_APP=wsgi.py
FLASK_ENV=development

# Database Configuration
# PostgreSQL: postgresql+psycopg://user:password@host:port/database
# SQLite: sqlite:///path/to/database.db (or leave empty for default)
SQLALCHEMY_DATABASE_URI=postgresql+psycopg://user:password@localhost:5432/dbname
SQLALCHEMY_TRACK_MODIFICATIONS=False
WTF_CSRF_TIME_LIMIT=3600

# Email Configuration (for password reset)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@flaskblog.com

