# Flask Configuration
SECRET_KEY=your-secret-key-here
FLASK_APP=wsgi.py
FLASK_ENV=development

# Database Configuration
# PostgreSQL: postgresql+psycopg://user:password@host:port/database
# SQLite: sqlite:///path/to/database.db (or leave empty for default)
SQLALCHEMY_DATABASE_URI=postgresql+psycopg://user:password@localhost:5432/dbname
SQLALCHEMY_TRACK_MODIFICATIONS=False
WTF_CSRF_TIME_LIMIT=3600
